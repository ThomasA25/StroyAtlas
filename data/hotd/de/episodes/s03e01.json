		"events": [
			{ "id": "s03e01-ev1", "title": "Rhaena bindet sich an Schafsdieb", "location_id": "the-vale", "characters_involved": ["rhaena-targaryen"], "summary": "Rhaena bindet sich endlich an den wilden Drachen Schafsdieb und wird zur Drachenreiterin.", "order_index": 0 },
			{ "id": "s03e01-ev6", "title": "Aegon und Larys fliehen aus der Hauptstadt", "location_id": "kings-landing", "characters_involved": ["aegon-ii-targaryen", "larys-strong"], "summary": "Nachdem Aegon den Thron aufgegeben hat, schleicht er sich verkleidet mit Larys aus Königsmund und flieht über Land aus der Hauptstadt.", "order_index": 1 },
			{ "id": "s03e01-ev2", "title": "Aegon und Larys gefangen genommen", "location_id": "the-riverlands", "characters_involved": ["aegon-ii-targaryen", "larys-strong"], "summary": "Auf der Straße durch die Flusslande werden die beiden von Rhaenyras Truppen gefasst; Larys gibt ihre Identität preis, in der Hoffnung, als wertvolle Geiseln gehalten zu werden.", "order_index": 2 },
			{ "id": "s03e01-ev3", "title": "Aemond beansprucht den Eisernen Thron", "location_id": "red-keep", "characters_involved": ["alicent-hightower", "aemond-targaryen"], "summary": "Alicent findet Aemond nach Aegons offenkundiger Abdankung auf dem Eisernen Thron sitzend; sie fälscht Briefe, um die Hohenturm-Verstärkungen zu verzögern, und drängt Aemond Richtung Harrenhal.", "order_index": 3 },
			{ "id": "s03e01-ev4", "title": "Daemon schlägt die Lannisters", "location_id": "the-riverlands", "characters_involved": ["daemon-targaryen", "roderick-dustin", "jason-lannister"], "summary": "Daemon erringt einen Sieg über Jason Lannisters Heer und gewinnt die Winterwölfe; Roderick Dustin präsentiert Jason Lannisters abgeschlagenen Kopf.", "order_index": 4, "deaths": ["jason-lannister"] },
			{ "id": "s03e01-ev7", "title": "Drachen starten von Drachenstein", "location_id": "dragonstone", "characters_involved": ["jacaerys-velaryon", "baela-targaryen"], "summary": "Als die Nachricht vom Angriff der Triarchie Drachenstein erreicht, besteigt Jacaerys Vermax und Baela Mondtänzerin, um der Velaryon-Flotte zu Hilfe zu fliegen.", "order_index": 5 },
			{ "id": "s03e01-ev5", "title": "Schlacht am Schlund; Tod des Jacaerys", "location_id": "the-gullet", "characters_involved": ["corlys-velaryon", "jacaerys-velaryon", "baela-targaryen", "addam-of-hull", "alyn-of-hull"], "summary": "Die Triarchie greift die Velaryon-Flotte am Schlund an und plündert Hohe Flut auf Driftmark; Jacaerys und Baela fangen die Angreifer auf Drachen ab, Addam stößt auf Seerauch dazu, und Alyn of Hull erschlägt den feindlichen Admiral. Corlys wird über Bord gerammt, und Jacaerys und sein Drache Vermax werden abgeschossen und getötet.", "order_index": 6, "deaths": ["jacaerys-velaryon"] }
